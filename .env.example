# Trading Engine Configuration
# Copy this file to .env and fill in the values

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=debug # debug, release

# Database Configuration (shared instance + table prefix)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=trading_engine
DB_TABLE_PREFIX=sess_1e7e3c6a_

# Redis Configuration (key prefix isolation)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=sess:1e7e3c6a:

# NATS Configuration
NATS_URL=nats://localhost:4222
NATS_MARKET_DATA_SUBJECT=market.price
NATS_MARKET_DATA_QUEUE=trading-engine

# Core Assets URL (external API for asset list)
CORE_BASE_URL=http://localhost:8081

# Assets API Key (if required)
CORE_API_KEY=

# Logging
LOG_LEVEL=info # debug, info, warn, error
LOG_FORMAT=json # json, console

# Performance Tuning
# Number of orderbook shards (should match CPU cores)
ORDERBOOK_SHARDS=4

# Snapshot settings
SNAPSHOT_INTERVAL=300 # seconds
SNAPSHOT_PATH=./data/snapshots

# Outbox settings
OUTBOX_PATH=./data/outbox
OUTBOX_BATCH_SIZE=100
OUTBOX_FLUSH_INTERVAL=5 # seconds

# Market limits
MAX_MARKETS=2000
MAX_USERS_PER_MARKET=500
MAX_OPEN_ORDERS_PER_USER=100
