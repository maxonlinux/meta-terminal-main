# META-TERMINAL-GO Configuration
# Copy this file to .env and modify as needed

# NATS connection
NATS_URL=nats://localhost:4222
NATS_TOKEN=

# NATS prices (from meta-multiplexer-fastify)
NATS_PRICE_SUBJECT=prices.*

# Stream prefix for NATS subjects
STREAM_PREFIX=meta

# JWT secret for authentication
JWT_SECRET=change-this-in-production

# HTTP server port
PORT=8080

# Snowflake node ID (0-1023)
SNOWFLAKE_NODE=0
